# =============================================================================
# iPhone User Guide RAG Chatbot — environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# =============================================================================

# --- LLM provider (OpenAI-compatible) ----------------------------------------
# API key used for BOTH the chat model and the embedding model.
# The reviewer fills this in with their own key before `docker run`.
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: override the OpenAI base URL (e.g. Azure OpenAI / a gateway).
# Leave blank to use the public OpenAI API.
OPENAI_BASE_URL=

# Chat model used by the agent (must support tool/function calling).
# Documented choice: gpt-4o (strong tool-use + instruction-following).
CHAT_MODEL=gpt-4o

# Sampling temperature. 0 = deterministic, best for grounded QA.
CHAT_TEMPERATURE=0

# Embedding model used at ingestion AND query time (MUST match the index).
# Documented choice: text-embedding-3-large (3072 dims).
EMBEDDING_MODEL=text-embedding-3-large

# Embedding vector dimensionality. MUST equal the dimension of the vector
# collection that was created during ingestion.
EMBEDDING_DIM=3072

# --- Vector backend -----------------------------------------------------------
# "qdrant" = Qdrant Cloud (managed). This is the backend the Docker image uses.
# "faiss"  = local on-disk index for offline development only (NOT bundled in
#            the image). Leave this as "qdrant" for the graded run.
VECTOR_BACKEND=qdrant
# The container is cloud-only and ships no FAISS index, so do NOT fall back: a
# Qdrant connection problem should surface clearly rather than silently failing
# on a missing local index. (Only set true for local dev with a built index.)
CLOUD_FALLBACK_TO_FAISS=false
# Local FAISS index path — used only when VECTOR_BACKEND=faiss (local dev).
FAISS_INDEX_PATH=.faiss_index

# --- Cloud vector database (Qdrant Cloud) ------------------------------------
# The cluster is ALREADY populated — no ingestion needed. Paste the two values
# we send you by email here (the cluster endpoint and its API key). Both are
# required: the URL alone will not authenticate.
#   QDRANT_URL  -> the cluster REST endpoint, including the :6333 port
#   QDRANT_API_KEY -> the read API key for that cluster
QDRANT_URL=
QDRANT_API_KEY=
# Collection name (already populated in the cluster — leave as-is).
QDRANT_COLLECTION=iphone-user-guide

# --- Retrieval tuning ---------------------------------------------------------
# Final number of chunks (child passages) passed to the LLM as context.
# Also live-tunable per conversation in the ⚙️ settings panel.
RETRIEVAL_TOP_K=10

# Candidates fetched from EACH channel (dense + sparse) before fusion.
RETRIEVAL_FETCH_K=40

# Minimum cosine similarity for a chunk to be relevant (grounding gate in
# dense mode / when the reranker is unavailable).
SCORE_THRESHOLD=0.30

# --- Hierarchical (coarse-to-fine) retrieval ---------------------------------
# Two-stage retrieval tuned to the guide's chapters/sections: first pick the
# top-N most relevant SECTIONS (via section centroids), then run hybrid chunk
# retrieval restricted to those sections. Set ENABLE_HIERARCHICAL=false to fall
# back to flat retrieval over all chunks.
ENABLE_HIERARCHICAL=true
# Top-N sections kept by the coarse stage. Also live-tunable in the UI.
COARSE_SECTIONS_N=5
# Sparse channel of the coarse stage: rank each section by the SUM of its top-K
# child BM25 scores. 3 aggregates a few strong hits (robust); 1 = rank by the
# single best child only (previous behaviour).
COARSE_SPARSE_TOPK=3
# On-disk section index (centroids + titles), written by ingestion.
SECTIONS_PATH=.sections.json

# --- Hybrid retrieval (dense + BM25, fused with weighted RRF) -----------------
# "hybrid" = semantic + BM25 fused; "dense" = embeddings only.
RETRIEVAL_MODE=hybrid
RRF_K=60
RRF_WEIGHT_DENSE=1.0
RRF_WEIGHT_SPARSE=1.0
# On-disk BM25 corpus (written by ingestion, rebuilt in-memory at serve time).
BM25_CORPUS_PATH=.bm25_corpus.json

# --- Reranking (Cohere Rerank via the OpenAI-compatible gateway) --------------
# Requires OPENAI_BASE_URL to point at a gateway exposing a /rerank endpoint.
# With the public OpenAI API this is unavailable and is skipped automatically.
USE_RERANKER=true
RERANK_MODEL=bedrock.cohere.rerank-3-5
RERANK_ENDPOINT_PATH=/rerank
RERANK_TOP_N_MULTIPLIER=3.0
# Minimum reranker relevance to keep a passage (grounding gate when reranking).
RERANK_SCORE_THRESHOLD=0.05

# --- Tool-calling agent -------------------------------------------------------
# The model decides, per turn, which tool to use:
#   search_guide(query)            -> one focused topic
#   search_guide_parallel(queries) -> several distinct topics, retrieved at once
# It greets / refuses out-of-scope directly. This caps the agent<->tools loop.
AGENT_MAX_TOOL_CALLS=6
# Thread-pool size for the parallel multi-query tool (bounded fan-out).
RETRIEVAL_MAX_WORKERS=4
# Hard cap on how many sub-queries a single parallel call will run.
MAX_PARALLEL_QUERIES=6

# --- Faithfulness / grounding verification ------------------------------------
# Post-generation check that the answer's claims are supported by citations.
# Adds one LLM call per substantive answer; set false to save it.
ENABLE_FAITHFULNESS_CHECK=true
FAITHFULNESS_MIN_SCORE=0.6

# --- Parent-document (small-to-big) context expansion -------------------------
# Expand each retrieved chunk with its neighbours in the SAME section (reading
# order). Citations stay chunk-precise; only the context shown to the model grows.
ENABLE_PARENT_EXPANSION=true
PARENT_WINDOW=1

# --- Observability (LangSmith tracing + per-turn metrics) ---------------------
# Set LANGCHAIN_TRACING=true and provide a key to stream traces to LangSmith.
LANGCHAIN_TRACING=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=iphone-rag-chatbot
# LANGCHAIN_ENDPOINT=
SHOW_METRICS=true

# --- Robustness (timeouts + retries) ------------------------------------------
LLM_TIMEOUT=60
LLM_MAX_RETRIES=3
RERANK_MAX_RETRIES=3

# --- Long-term memory (rolling conversation summary) --------------------------
ENABLE_SUMMARY_MEMORY=true
# Start summarising once the conversation exceeds this many messages.
SUMMARY_AFTER_MESSAGES=8
SUMMARY_MAX_TOKENS=400

# --- Ingestion (only used by ingest/ingest.py; reviewers do NOT run this) -----
# Path to the source PDF inside the project.
PDF_PATH=data/iphone_user_guide.pdf
# Chunking strategy: semantic (embedding-similarity splits) or token.
CHUNK_STRATEGY=semantic
# Token-splitter parameters (used by the "token" strategy and as a fallback).
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=80
# Semantic chunker parameters.
SEMANTIC_WINDOW_SIZE=2
SEMANTIC_THRESHOLD_PERCENTILE=30
SEMANTIC_MIN_TOKENS=120
SEMANTIC_MAX_TOKENS=512

# --- App runtime --------------------------------------------------------------
# Port the Chainlit UI listens on (document this in the README for -p mapping).
PORT=8000

# Recent messages kept verbatim; older turns fold into the rolling summary.
MAX_HISTORY_MESSAGES=8

# Logging verbosity: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO
